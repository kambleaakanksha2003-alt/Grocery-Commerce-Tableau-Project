        <zone flipboard-zone-id='5' forceUpdate='true' h='22407' id='6' story-point-id='1' type-v2='text' w='40676' x='55594' y='1349'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>This box plot represents delivery time variation from 2024 to 2029.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>The distribution appears stable across all years, with no extreme spikes or major fluctuations.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>This shows that the company has maintained consistent delivery performance over time. Even if order volume changes, operational efficiency remains balanced.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Overall, the business demonstrates steady and controlled delivery management across years</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{5E0AE3EB-F17F-48E8-BF8F-BAD449229E52}' />
    </dashboard>

    <worksheet name='Sheet 8'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Category-wise Order Count vs Delivery Time Analysis</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='11'>This chart compares total order count and total delivery time across different product categories. Dairy and Snacks show the highest delivery time impact.</run>
            <run bold='true' fontsize='11'>e Min.</run>
          </formatted-text>
        </caption>
      </layout-options>

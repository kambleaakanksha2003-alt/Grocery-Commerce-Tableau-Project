    <dashboard name='Story 1' type='storyboard'>
      <style />
      <size maxheight='764' maxwidth='1616' minheight='764' minwidth='1616' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97906' id='1' param='vert' removable='false' type-v2='layout-flow' w='99010' x='495' y='1047'>
            <zone h='5497' id='3' type-v2='title' w='99010' x='495' y='1047' />
            <zone h='13220' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99010' x='495' y='6544' />
            <zone h='79189' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99010' x='495' y='19764'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point captured-sheet='Sheet 8' id='1' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='35209' id='6' story-point-id='1' type-v2='text' w='32178' x='68441' y='39267'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>This bar chart compares total order count and total delivery time across different product categories.
From the chart, we can observe that categories like Dairy and Snacks have higher order volumes, and as a result, they also show higher total delivery time.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>This indicates that delivery time increases with order volume. Categories with more customer demand naturally require more delivery effort.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Overall, high-demand categories significantly influence operational workload.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{9A08DF2F-EEE0-4B65-8805-EA97161360B9}' />
    </dashboard>
    <dashboard name='Story 2' type='storyboard'>
      <style />
      <size maxheight='964' maxwidth='1716' minheight='964' minwidth='1716' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='99068' x='466' y='830'>
